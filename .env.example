FLASK_SECRET_KEY=generate-a-random-value-e.g-python-c-import-secrets-print-secrets.token_hex(32)
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
ALLOWED_EMAILS=you@example.com,someoneelse@example.com
OWNER_EMAIL=you@example.com
OAUTHLIB_INSECURE_TRANSPORT=1
# FLASK_DEBUG=1 enables Flask's interactive debugger/reloader. Leave unset (or 0) in production —
# it leaks stack traces and allows arbitrary code execution via the debugger console.
FLASK_DEBUG=0
